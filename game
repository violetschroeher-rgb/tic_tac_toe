"""Requirements
• Display a 3×3 board
• Players take turns (X and O)
• Accept user input for row and column (0–2 or 0–2)
• Prevent invalid moves (e.g., selecting an already occupied cell) or co-ordinates
outside the board
• Detect:
o Winning conditions (rows, columns, diagonals)
o Draw condition (board full, no winner)
Implementation Details
• Use a list of lists to represent the board
• Some of the functions:
o print_board(board)
o check_winner(board, player)
o is_draw(board)
• Alternate turns until game ends"""
class Player:
    # Define a player with a symbol attribute and whether it is their turn
    # symbols get automatically assigned from game class
    def __init__(self, symbol):
        self.symbol = symbol
        self.isTurn =False

    # while it is the current players turn, allow them to enter the row and column that they want
    # check that the input is an int and within the bounds
    # finally change the symbol on the board itself if conditions are passed
    def take_turn(self, board):
        isTurn = True
        while isTurn:
            row = int(input(f"Player {self.symbol} - enter row (0-2): "))
            col = int(input(f"Player {self.symbol} - enter col (0-2): "))
            if type(row)==int and type(col)==int:
                if not (0 <= row <= 2 and 0 <= col <= 2):
                    print("Out of range, use 0, 1, or 2.")
                elif board[row][col] != '-':
                    print("Choose another spot")
                else:
                    board[row][col] = self.symbol
                    isTurn = False

            else:
                print("Enter an integer")
        pass

class Board:
    # initialize the board with an 'empty' list of lists
    def __init__(self):
        self.board = [['-','-','-'],['-','-','-'],['-','-','-']]
    # iterate through the nested list and print each symbol
    def print_board(self):
        for row in range(len(self.board)):
            print(" " + " | ".join(self.board[row]))
            if row == 1 or row == 0:
                print(" --+---+--")

        
class Game:
    # initialize the game by setting up a board and two players - symbols x and o
    # set the current player to X
    # set the gameEnd to false so we know it is an active gameboard

    def __init__(self):
        self.game = Board()
        self.players = [Player('X'), Player('O')]
        self.current_player_index = 0
        self.gameEnd = False
    # property method that returns the current player symbol
    @property
    def current_player(self):
        return self.players[self.current_player_index]
    
    # automatically runs when this program is run
    # prints the board and welcome message
    def start_game(self):
        print("Welcome to Tic-Tac-Toe!")
        self.game.print_board()
        # this loop runs through players, alternating turns, and prints the updated board each time
        # also checks whether the win or draw conditions are fulfilled and ends the game if so
        while not self.gameEnd:
            player = self.current_player
            player.take_turn(self.game.board)
            self.game.print_board()

            if self.check_winner():
                print(f"Player {player.symbol} wins!")
                self.gameEnd = True
            elif self.is_draw():
                print("It's a draw!")
                self.gameEnd = True
            else:
                self.current_player_index = 1 - self.current_player_index
        print("Game over!")

    # checks horizontally, vertically, and diagonally through the game board for a win condition
    # # returns true if found, false if not    
    def check_winner(self):
        board = self.game.board
        sym = self.current_player.symbol
        for i in range(0,3):
            col = []
            diag1 = []
            diag1 += board[i][i]
            diag2 =[]
            diag2+=board[i][2-i]
            win = [sym, sym, sym]
            for row in board:
                if row == win:
                    return True
                col += row[i]
            if col == win or diag1 ==win or diag2==win:
                return True
        return False
    # checks to see if the board is full by checking for the - 
    # returns true if there is a draw false if not    
    def is_draw(self):
        if '-' not in self.game.board[0] and '-' not in self.game.board[1] and '-' not in self.game.board[2]:
            return True
        else:
            return False
    
        
# starts the game when the file is run
if __name__ == "__main__":
    game = Game()
    game.start_game()

